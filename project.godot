; DoroPet — Live2D 桌寵
; Godot 4.6+ / gd_cubism v0.9.1

config_version=5

[application]

config/name="DoroPet"
config/description="Doro 桌面寵物 (Live2D)"
config/version="0.1.19"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://assets/doro/icon.png"

[display]

window/size/viewport_width=380
window/size/viewport_height=440
window/size/transparent=true
window/size/borderless=true
window/size/always_on_top=true
window/per_pixel_transparency/allowed=true
window/subwindows/embed_subwindows=false
window/stretch/mode="disabled"
window/stretch/aspect="ignore"

[audio]

driver/enable_input=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
viewport/transparent_background=true
anti_aliasing/quality/msaa_2d=3
textures/vram_compression/import_etc2_astc=true
textures/canvas_textures/default_texture_filter=3
textures/default_filters/use_nearest_mipmap_filter=false
textures/default_filters/anisotropic_filtering_level=4
environment/defaults/default_clear_color=Color(0, 0, 0, 0)

[editor_plugins]

enabled=PackedStringArray("res://addons/gd_cubism/plugin.cfg")
